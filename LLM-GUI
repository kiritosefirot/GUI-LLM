def get_nombre_capa(capa_str):
    # orden importante: primero los nombres más largos para evitar falsos matches
    orden = ["Conv2DTranspose", "MaxPooling2D", "BatchNormalization",
             "Bidirectional", "Embedding", "Attention", "Flatten",
             "Conv2D", "Conv1D", "Dense", "Dropout", "LSTM", "GRU"]
    for nombre in orden:
        if nombre in capa_str:
            return nombre
    return None

def get_tipo_salida(capa_str, tipo_anterior="1D"):
    nombre = get_nombre_capa(capa_str)
    if not nombre:
        return tipo_anterior
    t = SALIDA_TIPO.get(nombre, "1D")
    if t == "hereda":
        return tipo_anterior
    return t

def actualizar_codigo():
    texto_codigo.delete("1.0", "end")
    if not capas_elegidas:
        texto_codigo.insert("end", "# el código aparece aquí")
        return
    lineas = ["import tensorflow as tf", "",
              "modelo = tf.keras.Sequential(["]
    for capa in capas_elegidas:
        lineas.append(f"    {capa},")
    lineas.append("])")
    lineas.append("")
    lineas.append("modelo.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])")
    texto_codigo.insert("end", "\n".join(lineas))

