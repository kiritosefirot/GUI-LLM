def guardar_modelo():
    carpeta = filedialog.askdirectory(title="elegí carpeta para guardar")
    if carpeta:
        nombre = simpledialog.askstring("nombre", "nombre para este modelo:", initialvalue="mi_modelo")
        if nombre:
            datos = {"nombre": nombre, "capas": capas_elegidas}
            path_json = os.path.join(carpeta, f"{nombre}.json")
            with open(path_json, "w") as f:
                json.dump(datos, f, indent=2)
            if modelo_actual[0]:
                path_modelo = os.path.join(carpeta, f"{nombre}.keras")
                modelo_actual[0].save(path_modelo)
            messagebox.showinfo("guardado", f"guardado en:\n{carpeta}")

def cargar_modelo_existente():
    path = filedialog.askopenfilename(
        title="elegí un modelo guardado",
        filetypes=[("modelos", "*.json")])
    if path:
        with open(path, "r") as f:
            datos = json.load(f)
        capas_elegidas.clear()
        capas_elegidas.extend(datos["capas"])
        actualizar_codigo()
        limpiar(canvas_izq)
        limpiar(canvas_der)
        canvas_izq.create_text(175, 100,
                               text=f"modelo cargado:\n{datos['nombre']}\n\npresioná entrenar",
                               fill="white", font=("Courier", 12), justify="center")
        canvas_der.create_text(175, 150, text="red cargada ✓",
                               fill="black", font=("Courier", 16), justify="center")

