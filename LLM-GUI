def validar_y_entrenar(epocas_callback):
    if not capas_elegidas:
        messagebox.showerror("error", "no hay capas para entrenar")
        return
    _validar_desde(0, None, epocas_callback)

def _validar_desde(i, tipo_actual, epocas_callback):
    if i >= len(capas_elegidas):
        _verificar_final(epocas_callback)
        return

    capa_str = capas_elegidas[i]
    nombre = get_nombre_capa(capa_str)

    # ── caso 0: capa redundante duplicada (ej: Dropout→Dropout) ──
    if nombre in ("Dropout", "BatchNormalization") and i > 0:
        anterior_nombre = get_nombre_capa(capas_elegidas[i-1])
        if anterior_nombre == nombre:
            def _elim_dup(_, cb=epocas_callback, idx=i, ta=tipo_actual):
                del capas_elegidas[idx]
                actualizar_codigo()
                _validar_desde(idx, ta, cb)
            def _dejar_dup(cb=epocas_callback, idx=i, ta=tipo_actual):
                _validar_desde(idx + 1, tipo_actual, cb)
            _mostrar_opciones(
                f"Hay dos '{nombre}' seguidos.\n"
                f"Eso es redundante y no aporta nada al modelo.",
                [("Eliminar el segundo '" + nombre + "'", "__eliminar__")],
                _elim_dup, _dejar_dup, epocas_callback
            )
            return

    # ── caso 1: Embedding en el medio (solo puede ser primera capa) ──
    if nombre == "Embedding" and i > 0:
        def _elim_emb(_, cb=epocas_callback, idx=i, ta=tipo_actual):
            del capas_elegidas[idx]
            actualizar_codigo()
            _validar_desde(idx, ta, cb)
        def _dejar_emb(cb=epocas_callback, idx=i, ta=tipo_actual):
            messagebox.showwarning("advertencia", "TensorFlow tirará error con Embedding en el medio.")
            _validar_desde(idx + 1, "2D_seq", cb)
        _mostrar_opciones(
            "Embedding solo puede ser la PRIMERA capa.\n"
            "En el medio no tiene sentido y TensorFlow tirará error.",
            [("Eliminar Embedding de esta posición", "__eliminar__")],
            _elim_emb, _dejar_emb, epocas_callback
        )
        return

    # ── caso 2: Attention en Sequential (siempre falla) ──
    if nombre == "Attention":
        def _elim_att(_, cb=epocas_callback, idx=i, ta=tipo_actual):
            del capas_elegidas[idx]
            actualizar_codigo()
            _validar_desde(idx, ta, cb)
        def _dejar_att(cb=epocas_callback, idx=i, ta=tipo_actual):
            nuevo_tipo = get_tipo_salida(capa_str, tipo_actual or "1D")
            _validar_desde(idx + 1, nuevo_tipo, cb)
        _mostrar_opciones(
            "Attention en Sequential no funciona correctamente.\n"
            "Necesita query y value por separado (API funcional).\n"
            "En Sequential siempre tirará error.",
            [("Eliminar Attention de la estructura", "__eliminar__")],
            _elim_att, _dejar_att, epocas_callback
        )
        return

    # ── caso 3: primera capa necesita Flatten si es Dense/Dropout/BatchNorm ──
    if i == 0 and nombre in ("Dense", "Dropout", "BatchNormalization"):
        def _si_flat(codigo, cb=epocas_callback):
            insertar_capa(codigo, 0)
            _validar_desde(1, "1D", cb)
        def _no_flat(cb=epocas_callback):
            _validar_desde(1, get_tipo_salida(capa_str, "1D"), cb)
        _mostrar_opciones(
            f"'{nombre}' como primera capa necesita Flatten antes\n"
            f"para conocer la forma de la imagen de entrada (28×28×1).",
            [("Flatten(input_shape=(28,28,1))  — aplana imagen 28×28",
              "tf.keras.layers.Flatten(input_shape=(28,28,1))")],
            _si_flat, _no_flat, epocas_callback
        )
        return

    # ── caso 4: incompatibilidad de tipos entre capas consecutivas ──
    if nombre and tipo_actual is not None:
        tipo_requerido = ENTRADA_TIPO.get(nombre, "cualquiera")
        if tipo_requerido != "cualquiera" and tipo_actual != tipo_requerido:
            soluciones = SOLUCIONES.get((tipo_actual, tipo_requerido), [])
            anterior = get_nombre_capa(capas_elegidas[i-1]) if i > 0 else "?"

            # armar lista de opciones: puentes + eliminar
            opciones_completas = list(soluciones)  # copiar para no modificar el original

            # siempre agregar opción de eliminar la capa incompatible al final
            opciones_completas.append(
                ("Eliminar '" + nombre + "' de la estructura", "__eliminar__")
            )

            def _accion(codigo, cb=epocas_callback, idx=i, ta=tipo_actual):
                if codigo == "__eliminar__":
                    del capas_elegidas[idx]
                    actualizar_codigo()
                    _validar_desde(idx, ta, cb)
                else:
                    insertar_capa(codigo, idx)
                    tipo_nuevo = get_tipo_salida(codigo, ta)
                    _validar_desde(idx + 1, tipo_nuevo, cb)

            def _ignorar(cb=epocas_callback, idx=i, ta=tipo_actual):
                messagebox.showwarning("advertencia",
                    "TensorFlow tirará error con esta estructura.")
                nuevo_tipo = get_tipo_salida(capas_elegidas[idx], ta)
                _validar_desde(idx + 1, nuevo_tipo, cb)

            if soluciones:
                msg = (f"'{anterior}' produce {tipo_actual}\n"
                       f"pero '{nombre}' necesita {tipo_requerido}.\n\n"
                       f"Opciones para resolver:")
            else:
                msg = (f"'{anterior}' produce {tipo_actual}\n"
                       f"pero '{nombre}' necesita {tipo_requerido}.\n\n"
                       f"No existe puente posible. Solo podés eliminar '{nombre}':")

            _mostrar_opciones(msg, opciones_completas, _accion, _ignorar, epocas_callback)
            return

    # ── sin problema → avanzar ──
    nuevo_tipo = get_tipo_salida(capa_str, tipo_actual or "1D") if nombre else tipo_actual
    _validar_desde(i + 1, nuevo_tipo, epocas_callback)

def _verificar_final(epocas_callback):
    capas = capas_elegidas
    if not capas:
        epocas_callback()
        return

    ultimo_nombre = get_nombre_capa(capas[-1])
    es_dense_salida = (
        ultimo_nombre == "Dense" and
        ("sigmoid" in capas[-1] or "softmax" in capas[-1])
    )
    if es_dense_salida:
        epocas_callback()
        return

    tipo_ultimo = get_tipo_salida(capas[-1], "1D")

    if tipo_ultimo != "1D":
        # necesita Flatten + Dense al final
        def _si(_, cb=epocas_callback):
            capas_elegidas.append("tf.keras.layers.Flatten()")
            capas_elegidas.append("tf.keras.layers.Dense(1, activation='sigmoid')")
            actualizar_codigo()
            cb()
        def _no(cb=epocas_callback):
            messagebox.showwarning("advertencia", "TensorFlow tirará error sin capa de salida.")
            cb()
        _mostrar_opciones(
            f"La última capa '{ultimo_nombre}' produce {tipo_ultimo}\n"
            f"y no puede ser capa de salida.\n"
            f"Hay que aplastar y agregar Dense al final.",
            [("Flatten + Dense(1, sigmoid)", "__flatten_dense__")],
            _si, _no, epocas_callback
        )
    else:
        def _si(codigo, cb=epocas_callback):
            capas_elegidas.append(codigo)
            actualizar_codigo()
            cb()
        def _no(cb=epocas_callback):
            messagebox.showwarning("advertencia", "Sin Dense final el modelo no producirá resultados válidos.")
            cb()
        _mostrar_opciones(
            f"La última capa es '{ultimo_nombre}'.\n"
            f"La red necesita terminar con Dense(sigmoid o softmax)\n"
            f"para producir un resultado final.",
            [("Dense(1, sigmoid)  — clasificación binaria",
              "tf.keras.layers.Dense(1, activation='sigmoid')"),
             ("Dense(10, softmax) — clasificación múltiple",
              "tf.keras.layers.Dense(10, activation='softmax')")],
            _si, _no, epocas_callback
        )

def _mostrar_opciones(mensaje, opciones, callback_si, callback_no, epocas_callback=None):
    win = tk.Toplevel(ventana)
    win.title("problema detectado")
    win.configure(bg="#18181b")
    win.grab_set()

    alto = 130 + len(opciones) * 50 + 50
    win.geometry(f"440x{alto}")

    tk.Label(win, text=mensaje,
             bg="#18181b", fg="white",
             font=("Courier", 10), justify="left",
             wraplength=410).pack(padx=15, pady=15, anchor="w")

    tk.Label(win, text="── opciones disponibles ──",
             bg="#18181b", fg="#a1a1aa",
             font=("Courier", 9)).pack()

    for nombre_op, codigo_op in opciones:
        def hacer(c=codigo_op, w=win, cb=callback_si):
            w.destroy()
            cb(c)
        tk.Button(win, text=nombre_op, command=hacer,
                  bg="#1D9E75", fg="white",
                  font=("Courier", 10), relief="flat",
                  anchor="w").pack(pady=3, padx=15, fill="x")

