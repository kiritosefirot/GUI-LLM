def agregar_capa(neurona, unidades):
    nombre = neurona["nombre"]
    es_primera = not capas_elegidas

    def inp(shape): return f", input_shape={shape}" if es_primera else ""

    if nombre == "Dense":
        capa = f"tf.keras.layers.Dense({unidades}, activation='relu')"
    elif nombre == "Conv2D":
        capa = f"tf.keras.layers.Conv2D({unidades}, (3,3), activation='relu'{inp('(28,28,1)')})"
    elif nombre == "SeparableConv2D":
        capa = f"tf.keras.layers.SeparableConv2D({unidades}, (3,3), activation='relu'{inp('(28,28,1)')})"
    elif nombre == "DepthwiseConv2D":
        capa = f"tf.keras.layers.DepthwiseConv2D((3,3), activation='relu'{inp('(28,28,1)')})"
    elif nombre == "Conv2DTranspose":
        capa = f"tf.keras.layers.Conv2DTranspose({unidades}, (3,3), activation='relu'{inp('(28,28,1)')})"
    elif nombre == "ZeroPadding2D":
        capa = f"tf.keras.layers.ZeroPadding2D((1,1){inp('(28,28,1)')})"
    elif nombre == "MaxPooling2D":
        capa = f"tf.keras.layers.MaxPooling2D((2,2))"
    elif nombre == "GlobalAveragePooling2D":
        capa = f"tf.keras.layers.GlobalAveragePooling2D()"
    elif nombre == "Conv1D":
        capa = f"tf.keras.layers.Conv1D({unidades}, 3, activation='relu'{inp('(28,28)')})"
    elif nombre == "MaxPooling1D":
        capa = f"tf.keras.layers.MaxPooling1D(2)"
    elif nombre == "GlobalAveragePooling1D":
        capa = f"tf.keras.layers.GlobalAveragePooling1D()"
    elif nombre == "LSTM":
        capa = f"tf.keras.layers.LSTM({unidades}{inp('(28,28)')})"
    elif nombre == "GRU":
        capa = f"tf.keras.layers.GRU({unidades}{inp('(28,28)')})"
    elif nombre == "SimpleRNN":
        capa = f"tf.keras.layers.SimpleRNN({unidades}{inp('(28,28)')})"
    elif nombre == "Bidirectional":
        capa = f"tf.keras.layers.Bidirectional(tf.keras.layers.LSTM({unidades}){inp('(28,28)')})"
    elif nombre == "Embedding":
        capa = f"tf.keras.layers.Embedding(10000, {unidades})"
    elif nombre == "MultiHeadAttention":
        capa = f"tf.keras.layers.MultiHeadAttention(num_heads=4, key_dim={unidades})"
    elif nombre == "Attention":
        capa = "tf.keras.layers.Attention()"
    elif nombre == "Flatten":
        if es_primera:
            capa = "tf.keras.layers.Flatten(input_shape=(28,28,1))"
        else:
            capa = "tf.keras.layers.Flatten()"
    elif nombre == "Reshape":
        forma = simpledialog.askstring("Reshape",
            "¿A qué forma? (ej: (7,7,1) o (784,))",
            initialvalue="(7,7,1)")
        capa = f"tf.keras.layers.Reshape({forma or '(784,)'})"
    elif nombre == "Dropout":
        capa = "tf.keras.layers.Dropout(0.5)"
    elif nombre == "BatchNormalization":
        capa = "tf.keras.layers.BatchNormalization()"
    elif nombre == "LayerNormalization":
        capa = "tf.keras.layers.LayerNormalization()"
    else:
        capa = f"tf.keras.layers.{nombre}({unidades})"

    capas_elegidas.append(capa)
    actualizar_codigo()
    preguntar_opcionales(neurona, 0)

def preguntar_opcionales(neurona, idx):
    opcionales = OPCIONALES.get(neurona["nombre"], [])
    if idx >= len(opcionales):
        preguntar_otra_neurona()
        return
    op = opcionales[idx]
    resp = messagebox.askyesno("opcional", f"¿agregar {op}?")
    if resp:
        mapa = {
            "Dropout":            "tf.keras.layers.Dropout(0.5)",
            "MaxPooling2D":       "tf.keras.layers.MaxPooling2D((2,2))",
            "MaxPooling1D":       "tf.keras.layers.MaxPooling1D(2)",
            "BatchNormalization": "tf.keras.layers.BatchNormalization()",
            "LayerNormalization": "tf.keras.layers.LayerNormalization()",
        }
        if op in mapa:
            capas_elegidas.append(mapa[op])
            actualizar_codigo()
    preguntar_opcionales(neurona, idx + 1)

