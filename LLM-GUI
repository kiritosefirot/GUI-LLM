def pantalla_entrenando(epocas, continuar=False):
    limpiar(canvas_izq)
    limpiar(canvas_der)
    canvas_izq.create_text(175, 50, text="entrenando...",
                           fill="white", font=("Courier", 13))
    barra_frame = tk.Frame(canvas_izq, bg="blue")
    barra_frame.place(x=20, y=80, width=310, height=20)
    barra = tk.Canvas(barra_frame, bg="#18181b", highlightthickness=0)
    barra.place(x=0, y=0, width=310, height=20)
    label_progreso = tk.Label(canvas_izq, text=f"época 0 / {epocas}",
                              bg="blue", fg="white", font=("Courier", 10))
    label_progreso.place(x=20, y=110)
    label_acc = tk.Label(canvas_izq, text="precisión: -",
                         bg="blue", fg="#1D9E75", font=("Courier", 11))
    label_acc.place(x=20, y=140)

    fig, ax = plt.subplots(figsize=(3.5, 2.8), facecolor="#ffff00")
    ax.set_facecolor("#ffff00")
    ax.set_title("precisión", fontsize=9, color="black")
    ax.set_xlabel("época", fontsize=8, color="black")
    ax.set_ylabel("accuracy", fontsize=8, color="black")
    ax.tick_params(colors="black")
    linea, = ax.plot([], [], color="#1D9E75", linewidth=2)
    ax.set_xlim(0, epocas)
    ax.set_ylim(0, 1)
    fig_canvas = FigureCanvasTkAgg(fig, master=canvas_der)
    fig_canvas.get_tk_widget().place(x=0, y=0, width=350, height=300)
    grafica_canvas[0] = fig_canvas
    historial_acc = []

    def actualizar_grafica(epoca, acc):
        historial_acc.append(acc)
        linea.set_data(range(1, len(historial_acc)+1), historial_acc)
        fig_canvas.draw()
        barra.delete("all")
        ancho = int((epoca / epocas) * 310)
        barra.create_rectangle(0, 0, ancho, 20, fill="#1D9E75", outline="")
        label_progreso.config(text=f"época {epoca} / {epocas}")
        label_acc.config(text=f"precisión: {acc:.4f}")

    def entrenar():
        try:
            x = np.random.rand(100, 28, 28, 1).astype("float32")
            y = np.random.randint(0, 2, 100).astype("float32")

            # si continuar=True y ya hay modelo, lo reutiliza sin recompilar
            if continuar and modelo_actual[0] is not None:
                modelo = modelo_actual[0]
            else:
                modelo = tf.keras.Sequential()
                for capa_str in capas_elegidas:
                    modelo.add(eval(capa_str))
                modelo.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])
                modelo_actual[0] = modelo

            for epoca in range(1, epocas + 1):
                history = modelo.fit(x, y, epochs=1, verbose=0)
                acc = float(history.history["accuracy"][0])
                ventana.after(0, actualizar_grafica, epoca, acc)
            ventana.after(0, pantalla_resultado)
        except Exception as err:
            msg = str(err)
            ventana.after(0, lambda m=msg: messagebox.showerror("error", m))

    hilo = threading.Thread(target=entrenar, daemon=True)
    hilo.start()

def iniciar_entrenamiento():
